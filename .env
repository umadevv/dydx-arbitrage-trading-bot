# dYdX Configuration
# Get mnemonic from dYdX frontend: Export secret phrase
DYDX_MNEMONIC=your twenty four word mnemonic phrase here
DEPOSIT_SOL_ADDRESS=
SOL_PRIVATE_KEY=                         # requires SOL. it will be sended to the DEPOSIT_SOL_ADDRESS




# Network: mainnet | testnet
DYDX_NETWORK=mainnet

# Trading (comma-separated for multi-market)
DYDX_MARKETS=BTC-USD,ETH-USD,SOL-USD
DYDX_SUBACCOUNT_NUMBER=0
MIN_PROFIT_BPS=10
MAX_POSITION_SIZE=0.01
SLIPPAGE_BPS=50

# Set to false for monitor-only (no orders)
ENABLE_TRADING=false

# Simulation: real data, virtual execution (no real orders)
ENABLE_SIMULATION=false
SIM_INITIAL_BALANCE_USD=10000
SIM_MIN_PROFIT_BPS=1

# Speed: poll interval (ms), fetch timeout (ms)
POLL_INTERVAL_MS=300
FETCH_TIMEOUT_MS=15000

# HFT: WebSocket orderbook for dYdX (lower latency). Use POLL_INTERVAL_MS=50 for best results.
HFT_MODE=false
